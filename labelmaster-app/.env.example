# 보상형 광고 그룹 ID
# - 개발/샌드박스: ait-ad-test-rewarded-id (테스트 광고)
# - 운영: 앱인토스 콘솔에서 보상형 광고 그룹 생성 후 발급받은 ait.live... 값
VITE_AD_GROUP_ID=ait-ad-test-rewarded-id

# Firebase Analytics (사용자 행동 분석)
# Firebase 콘솔(label-wizard-co50gj) > 프로젝트 설정 > 웹 앱 추가 + GA4 연결 후 발급되는 값
# 비워두면 이벤트는 콘솔 로그만 남고 GA4로 전송되지 않아요.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# 토스 공유 OG 미리보기 이미지 (https 절대경로, 권장 1200×630). 비우면 토스 기본 미리보기 사용.
VITE_OG_IMAGE_URL=

# 일일 통계 대시보드(scripts/ga4-report.mjs)용 — Google Analytics Data API
# GA4_PROPERTY_ID: GA4 관리 > 속성 설정 > 속성 ID (숫자)
# GOOGLE_APPLICATION_CREDENTIALS: 서비스 계정 키(JSON) 경로 (GA4 액세스 관리에 뷰어로 추가)
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=
